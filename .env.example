# ─── Base de datos PostgreSQL (Neon) ─────────────────────────────────────────
# Obtener en: console.neon.tech → tu proyecto → Connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─── NextAuth / Auth.js ───────────────────────────────────────────────────────
# Generar con: openssl rand -base64 32
AUTH_SECRET="REEMPLAZAR_CON_VALOR_ALEATORIO_SEGURO"

# Requerido para NextAuth en producción (Vercel lo detecta automáticamente)
AUTH_TRUST_HOST="true"

# URL pública de la app (Vercel la pone automáticamente, pero es buena práctica explicitarla)
# NEXTAUTH_URL="https://tu-app.vercel.app"
